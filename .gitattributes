# 跨平台 (macOS / Win10) Git 行尾与二进制规范
# 目的: 仓库内文本文件统一以 LF 存储, checkout 时也按 LF (Win 上 bash 才不报 \r 错)
# 例外: Windows 原生脚本 (.bat/.cmd/.ps1) 强制 CRLF (cmd.exe/PowerShell 要求)

# ---- 默认: 自动识别文本, 文本统一 LF ----
* text=auto eol=lf

# ---- 文本文件显式声明 (避免被误判) ----
*.py        text eol=lf
*.sh        text eol=lf
*.command   text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.json      text eol=lf
*.toml      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.js        text eol=lf
*.mjs       text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.sql       text eol=lf
*.conf      text eol=lf
*.env       text eol=lf
*.example   text eol=lf
Dockerfile  text eol=lf
.gitignore  text eol=lf
.gitkeep    text eol=lf

# ---- Windows 原生脚本必须 CRLF ----
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf

# ---- 二进制: Git 不做行尾转换 / 不出 diff ----
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.svg       binary
*.pdf       binary
*.zip       binary
*.tar       binary
*.gz        binary
*.exe       binary
*.dll       binary
*.so        binary
*.dylib     binary
*.ipynb     binary
*.pem       binary
*.key       binary
*.crt       binary
*.p12       binary
*.pfx       binary
